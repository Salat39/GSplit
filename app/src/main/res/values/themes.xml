<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.GSplit.BaseAppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowContentOverlay">@null</item>
        <item name="colorPrimary">@color/system_background</item>
        <item name="colorPrimaryVariant">@color/system_background</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/system_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">default</item>
        <!-- 21-22 specials -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Theme.GSplit.AppTheme" parent="Theme.GSplit.BaseAppTheme" />

    <style name="Theme.GSplit.Starting" parent="Theme.SplashScreen">
        <item name="colorPrimaryVariant">@color/system_background</item>
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.GSplit.AppTheme</item>
    </style>

    <style name="Theme.TransparentNoSplash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@null</item>
    </style>

    <style name="Taskbar.InvisibleActivity" parent="@android:style/Theme.Material.Dialog.NoActionBar">
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
